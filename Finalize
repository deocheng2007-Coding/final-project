// =========================================
// STRUCT DEFINITIONS
// =========================================
struct Destination {
    double price;
    string name;
};

struct FlightBooking {
    int orderID;
    int dest;
    int tripType;
    int sClass;
    int pax;
    int bank;

    string destName;
    string tripName;
    string className;
    string bankName;

    string passengerNames[20];

    double baseFareOneWay;
    double foodTotal;
    double drinkTotal;
    double luggageWeight;
    double luggageCharge;
    double totalBill;
    double totalPaid;
    double balance;
};

const int MAX_DEST = 4; // GLOBAL CONSTANT

// --- PROTOTYPES ---
void displayHeader();
int getValidChoice(int min, int max);
int getValidIntMin(int minValue, const string& prompt);
int getValidIntRange(int minValue, int maxValue, const string& prompt);
double getValidDoubleMin(double minValue, const string& prompt);
void inputPassengers(FlightBooking& b);
void calculateTotal(FlightBooking& b);
double processPayment(double totalBill);
void displayReceipt(const FlightBooking& b);

double orderMultipleFoodForPassenger(const string& passengerName);
double orderMultipleDrinkForPassenger(const string& passengerName);

double getLuggageLimitPerPax(int sClass);
double getOverweightRatePerKg(int sClass);
double handleLuggage(FlightBooking& b);

int main() {
    // FOR RANDOM NUMBER (BOOKING ID)
    srand(time(0));

    Destination destList[MAX_DEST];

    // BACA FAIL INPUT
    ifstream fin("flight_data.txt");
    if (!fin) { // IF FILE DOESNT EXIST, THIS WILL SHOW
        cout << ">> Error: Could not open input file 'flight_data.txt'!\n";
        return 1;
    }

    for (int i = 0; i < MAX_DEST; i++) { // LOOP INSERT THE DATA FROM THE FILE INPUT
        fin >> destList[i].price;
        fin.ignore();
        getline(fin, destList[i].name); // USE GETLINE TO READ EVEN WITH WHITESPACE/SPACES
    }
    fin.close();

    FlightBooking b; // DEFINE AS 'b'
    char next; // VARIABLE TO KEEP YES OR NO QUESTION

    do {
        displayHeader();

        b.orderID = rand() % 90000 + 10000; // MATH FORMULA TO GENERATE RANDOM NUMBER :: REFF : LECTURE PROGRAMMING 1

        // DISPLAY MENU
        cout << "\n        --- SELECT DESTINATION ---\n";
        for (int i = 0; i < MAX_DEST; i++) {
            cout << (i + 1) << ". KLIA --> " << left << setw(18) << destList[i].name
                << " (RM " << fixed << setprecision(2) << destList[i].price << ")\n";
        }
        cout << "Choice: ";
        b.dest = getValidChoice(1, MAX_DEST);

        // LOGIC INDEX ARRAY
        b.baseFareOneWay = destList[b.dest - 1].price;
        b.destName = destList[b.dest - 1].name;

        // TRIP TYPE
        cout << "\n--- TRIP TYPE ---\n"
            << "1. One Way\n"
            << "2. Round Trip\n"
            << "Choice: ";
        b.tripType = getValidChoice(1, 2);
        b.tripName = (b.tripType == 1) ? "One Way" : "Round Trip";

        // PASSENGER DETAILS
        cout << "\n--- PASSENGER DETAILS ---\n";
        b.pax = getValidIntRange(1, 20, "Enter Number of Passengers (1-20): ");

        inputPassengers(b);

        // SELECT CLASS
        cout << "\n--- SELECT CLASS ---\n"
            << "1. Business (+RM 150.00)\n"
            << "2. Economy  (+RM 0.00)\n"
            << "Choice: ";
        b.sClass = getValidChoice(1, 2);
        b.className = (b.sClass == 1) ? "Business" : "Economy";

        system("cls");

        // FOOD & DRINK
        b.foodTotal = 0.0;
        b.drinkTotal = 0.0;

        for (int i = 0; i < b.pax; i++) {
            cout << "\n=================================\n";
            cout << " FOOD & DRINK ORDER BY PASSENGER\n";
            cout << "=================================\n";
            cout << "\n--- PASSENGER " << (i + 1) << ": " << b.passengerNames[i] << " ---\n";

            b.foodTotal += orderMultipleFoodForPassenger(b.passengerNames[i]);
            b.drinkTotal += orderMultipleDrinkForPassenger(b.passengerNames[i]);
            system("cls");
        }

        system("cls");

        // LUGGAGE
        b.luggageCharge = handleLuggage(b);

        system("cls");

        // PAYMENT BANK
        cout << "\n--- PAYMENT BANK ---\n"
            << "1. Bank Islam\n"
            << "2. Maybank\n"
            << "3. RHB Bank\n"
            << "Choice: ";
        b.bank = getValidChoice(1, 3);
        b.bankName = (b.bank == 1) ? "Bank Islam" : (b.bank == 2 ? "Maybank" : "RHB Bank");

        calculateTotal(b);

        cout << fixed << setprecision(2);
        cout << "\nTotal Amount Due: RM " << b.totalBill << "\n";

        b.totalPaid = processPayment(b.totalBill);
        b.balance = b.totalPaid - b.totalBill;

        system("cls");

        displayReceipt(b);

        cout << "\nBook another flight? (Y/N): ";
        cin >> next;
        system("cls");

    } while (next == 'Y' || next == 'y');

    cout << "Thank you for choosing AirAsia. Now Everyone Can Fly!\n";
    return 0;
}

