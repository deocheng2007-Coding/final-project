void displayHeader() {
    cout << "\n" << string(55, '=') << "\n";
    cout << setw(42) << right << "AIR-ASIA MOCK SYSTEM (KLIA)\n";
    cout << string(55, '=') << "\n";
}

int getValidChoice(int min, int max) {
    string input;
    int choice = 0;
    while (true) {
        cin >> input;
        char firstChar = input[0];
        if (input.length() == 1 && firstChar >= '0' && firstChar <= '9') {
            choice = firstChar - '0';
            if (choice >= min && choice <= max)
                return choice;
        }
        cout << "Invalid choice! Select between " << min << " and " << max << ": ";
    }
}

int getValidIntMin(int minValue, const string& prompt) {
    string input;
    int val = 0;
    while (true) {
        cout << prompt;
        getline(cin >> ws, input);
        bool isNumber = true;
        for (size_t i = 0; i < input.length(); i++) {
            if (input[i] < '0' || input[i] > '9') { isNumber = false; break; }
        }
        if (isNumber && input.length() > 0) {
            val = stoi(input);
            if (val >= minValue) return val;
            cout << "Invalid input! Minimum is " << minValue << ".\n";
        }
        else {
            cout << "Invalid input! Please enter a number.\n";
        }
    }
}

int getValidIntRange(int minValue, int maxValue, const string& prompt) {
    string input;
    int val = 0;
    while (true) {
        cout << prompt;
        getline(cin >> ws, input);
        if (input.length() == 0) { cout << "Invalid input! Please enter a number.\n"; continue; }
        bool isInteger = true;
        for (size_t i = 0; i < input.length(); i++) {
            if (input[i] < '0' || input[i] > '9') { 
                isInteger = false; break; }
        }
        if (!isInteger) { cout << "Invalid input! No letters or decimals allowed.\n"; continue; }
        val = 0;
        for (size_t i = 0; i < input.length(); i++) val = val * 10 + (input[i] - '0');
        if (val >= minValue && val <= maxValue) return val;
        cout << "Invalid input! Enter value between " << minValue << " and " << maxValue << ".\n";
    }
}

double getValidDoubleMin(double minValue, const string& prompt) {
    string input;
    double val = 0.0;
    while (true) {
        cout << prompt;
        getline(cin >> ws, input);
        bool isDouble = true;
        int decimalCount = 0;
        for (size_t i = 0; i < input.length(); i++) {
            if (input[i] == '.') {
                decimalCount++;
                if (decimalCount > 1) { isDouble = false; break; }
            }
            else if (input[i] < '0' || input[i] > '9') { isDouble = false; break; }
        }
        if (isDouble && input.length() > 0 && input != ".") {
            val = stod(input);
            if (val >= minValue) return val;
            cout << "Invalid input! Minimum is " << minValue << ".\n";
        }
        else {
            cout << "Invalid input! Please enter a numeric value.\n";
        }
    }
}

void inputPassengers(FlightBooking& b) {
    for (int i = 0; i < b.pax; i++) {
        cout << "Passenger " << (i + 1) << " Name (Single Word): ";
        cin >> b.passengerNames[i];
    }
}

double orderMultipleFoodForPassenger(const string& passengerName) {
    double total = 0.0;
    int choice;
    cout << "\n--- FOOD MENU (for " << passengerName << ") ---\n";
    while (true) {
        cout << "1. Nasi Lemak   (RM 15.00)\n" << "2. Chicken Rice (RM 12.00)\n" << "3. Pasta        (RM 18.00)\n" << "4. Done\nChoice: ";
        choice = getValidChoice(1, 4);
        if (choice == 4) break;
        int qty = getValidIntMin(1, "Quantity: ");
        double price = 0.0;
        if (choice == 1) price = 15.00;
        else if (choice == 2) price = 12.00;
        else if (choice == 3) price = 18.00;
        total += price * qty;
        cout << "\n>> Added. Current FOOD total for " << passengerName << ": RM " << fixed << setprecision(2) << total << "\n\n";
    }
    return total;
}

double orderMultipleDrinkForPassenger(const string& passengerName) {
    double total = 0.0;
    int choice;
    cout << "\n--- DRINK MENU (for " << passengerName << ") ---\n";
    while (true) {
        cout << "1. Coffee (RM 7.00)\n" << "2. Water  (RM 3.00)\n" << "3. Done\nChoice: ";
        choice = getValidChoice(1, 3);
        if (choice == 3) break;
        int qty = getValidIntMin(1, "Quantity: ");
        double price = (choice == 1) ? 7.00 : 3.00;
        total += price * qty;
        cout << "\n>> Added. Current DRINK total for " << passengerName << ": RM " << fixed << setprecision(2) << total << "\n\n";
    }
    return total;
}

double getLuggageLimitPerPax(int sClass) { 
    return (sClass == 1) ? 30.0 : 20.0; }

double getOverweightRatePerKg(int sClass) { 
    return (sClass == 1) ? 12.0 : 10.0; }

double handleLuggage(FlightBooking& b) {
    char hasLuggage;
    b.luggageWeight = 0.0;
    cout << "\n--- LUGGAGE OPTION ---\nDo you have check-in luggage? (Y/N): ";
    cin >> hasLuggage;
    if (!(hasLuggage == 'Y' || hasLuggage == 'y')) { cout << ">> No check-in luggage selected.\n"; return 0.0; }
    double limitPerPax = getLuggageLimitPerPax(b.sClass);
    double totalLimit = limitPerPax * b.pax;
    double ratePerKg = getOverweightRatePerKg(b.sClass);
    b.luggageWeight = getValidDoubleMin(0.0, "Enter TOTAL luggage weight for ALL passengers (kg): ");
    if (b.luggageWeight <= totalLimit) { cout << ">> Luggage accepted. No extra charge.\n"; return 0.0; }
    while (b.luggageWeight > totalLimit) {
        double excess = b.luggageWeight - totalLimit;
        double charge = excess * ratePerKg;
        cout << fixed << setprecision(2);
        cout << "\n!! OVERWEIGHT ALERT !!\n" << "Total Weight : " << b.luggageWeight << "kg\n" << "Free Limit   : " << totalLimit << "kg\n" << "Excess       : " << excess << "kg\n" << "Charge Rate  : RM " << ratePerKg << " / kg\n" << "Extra Charge : RM " << charge << "\n";
        cout << "\nDo you want to PAY the extra charge? (Y/N): ";
        char pay; cin >> pay;
        if (pay == 'Y' || pay == 'y') { cout << ">> Overweight payment accepted.\n"; return charge; }
        else {
            cout << ">> Please reduce weight to " << totalLimit << "kg or below.\n";
            b.luggageWeight = getValidDoubleMin(0.0, "Enter NEW total luggage weight (kg): ");
            if (b.luggageWeight <= totalLimit) { cout << ">> Weight reduced successfully. No extra charge.\n"; return 0.0; }
        }
    }
    return 0.0;
}

void calculateTotal(FlightBooking& b) {
    double classExtra = (b.sClass == 1) ? 150.00 : 0.0;
    double tripMultiplier = (b.tripType == 2) ? 2.0 : 1.0;
    double basePart = (b.baseFareOneWay * tripMultiplier + classExtra) * b.pax;
    double addOns = b.foodTotal + b.drinkTotal + b.luggageCharge;
    b.totalBill = basePart + addOns;
}

double processPayment(double totalBill) {
    double payment, totalPaid = 0;
    while (totalPaid < totalBill) {
        cout << "Enter Payment Amount (Remaining: RM " << fixed << setprecision(2) << (totalBill - totalPaid) << "): RM ";
        cin >> payment; totalPaid += payment;
        if (totalPaid < totalBill) cout << ">> Insufficient amount! Please pay more.\n";
    }
    return totalPaid;
}

